# Foot bot — copier vers env/foot.env (gitignoré) et remplir les secrets via env/common.env

API_FOOTBALL_KEY=
OPENWEATHER_KEY=

# Kelly adaptatif Brier
FOOT_KELLY_BRIER_ACTIF=true
FOOT_KELLY_BRIER_FENETRE=40
FOOT_KELLY_BRIER_MIN_PARIS=20
FOOT_KELLY_BSS_SENSIBILITE=0.30
FOOT_KELLY_BSS_MULT_MIN=0.4

# Tracker CLV Telegram (H-1h / H-5min) — event odds + alternate_totals/spreads
FOOT_CLV_LIGNE_TOL=0.26
FOOT_CLV_SCORE_MIN=80
FOOT_CLV_SCORE_MIN_RELAX=75
FOOT_CLV_ALERT_ECHEC=true
FOOT_CLV_DOUBLE_PASS=true

# Alerte monitoring CLV moyen (Telegram only — n'influence pas les paris)
FOOT_CLV_ALERT_MOYENNE=true
FOOT_CLV_ALERT_FENETRE=20
FOOT_CLV_ALERT_SEUIL=-0.02
FOOT_CLV_ALERT_COOLDOWN_H=12

# Fenêtre prise de paris (heures avant KO) — centrée sur H-24 = backtest bt_odds_h24
FOOT_SCAN_HEURES_MAX=26
FOOT_SCAN_HEURES_MIN=22

# Calibration P(couverture) AH (foot_calibration_ah.json via backtest --fit-calibration platt)
FOOT_CALIB_AH=true
# FOOT_CALIB_AH_FILE=foot_calibration_ah.json

# Preset P1 volume AH (parité backtest --p1-ah) — totaux inchangés
# Cap désactivé (0) : non fiable en live (FIFO ≠ top EV)
FOOT_P1_AH=true
FOOT_EV_MAX_AH=0.09
FOOT_EV_MIN_AH_TIER=true
FOOT_AH_MAX_LIGUE_SAISON=0

# Filtre fatigue AH only (totaux inchangés) — congestion / repos / coupe UEFA
FOOT_FATIGUE_AH_ACTIF=true
FOOT_FATIGUE_FENETRE_J=7
FOOT_FATIGUE_MAX_MATCHS=3
FOOT_FATIGUE_MIN_REPOS_J=3
FOOT_FATIGUE_CUP_ACTIF=true
FOOT_FATIGUE_CUP_HEURES=72
FOOT_FATIGUE_AH_MODE=either

# Steam / line movement AH (live only — snapshots Pinnacle dans foot_odds_history.json)
FOOT_STEAM_ACTIF=true
FOOT_STEAM_MIN_AGE_MIN=45
FOOT_STEAM_MAX_SNAPSHOTS=48
FOOT_STEAM_WARN_PCT=0.025
FOOT_STEAM_BLOCK_PCT=0.05
FOOT_STEAM_EV_EXTRA=0.015
# FOOT_STEAM_FILE=foot_odds_history.json

# Shrink AH model ↔ no-vig Pinnacle (totaux inchangés ; remplace blend poids_dyn sur AH)
FOOT_AH_SHRINK_ACTIF=true
FOOT_AH_SHRINK_W=0.70

# XI probable H-24 (titulaires habituels absents via /injuries) — live only, pas de BT
FOOT_XI_PROBABLE_ACTIF=true
FOOT_XI_TOLERANCE=2
FOOT_XI_MALUS_PAR_ABSENT=0.05
FOOT_XI_MALUS_MAX=0.25
# Proxy rotation avant lineups : fatigue / coupe UEFA juste après → malus λ
FOOT_XI_ROTATION_ACTIF=true
FOOT_XI_CUP_APRES_MALUS=0.10
FOOT_XI_FATIGUE_MALUS=0.05
# Audit XI probable vs officiel → Telegram avant KO
FOOT_XI_AUDIT_ACTIF=true
FOOT_XI_AUDIT_HEURES_MAX=1.5
FOOT_XI_AUDIT_HEURES_MIN=0.05

# Alerte monitoring API down (Telegram only — n'influence pas les paris)
FOOT_API_ALERT=true
FOOT_API_ALERT_SEUIL=3
FOOT_API_ALERT_COOLDOWN_H=6

# Export CSV dashboard (PythonAnywhere)
# FOOT_HISTORIQUE_CSV=/home/chienblanc/data/historique_sniper.csv
# FOOT_CSV_LEGACY=/home/chienblanc/historique_sniper.csv
