# Foot bot — copier vers env/foot.env (gitignoré) et remplir les secrets via env/common.env

API_FOOTBALL_KEY=
OPENWEATHER_KEY=

# Kelly adaptatif Brier
FOOT_KELLY_BRIER_ACTIF=true
FOOT_KELLY_BRIER_FENETRE=40
FOOT_KELLY_BRIER_MIN_PARIS=20
FOOT_KELLY_BSS_SENSIBILITE=0.30
FOOT_KELLY_BSS_MULT_MIN=0.4

# Tracker CLV Telegram (H-1h / H-5min) — event odds + alternate_totals/spreads
FOOT_CLV_LIGNE_TOL=0.26
FOOT_CLV_SCORE_MIN=80
FOOT_CLV_SCORE_MIN_RELAX=75
FOOT_CLV_ALERT_ECHEC=true
FOOT_CLV_DOUBLE_PASS=true

# Alerte monitoring CLV moyen (Telegram only — n'influence pas les paris)
FOOT_CLV_ALERT_MOYENNE=true
FOOT_CLV_ALERT_FENETRE=20
FOOT_CLV_ALERT_SEUIL=-0.02
FOOT_CLV_ALERT_COOLDOWN_H=12

# Fenêtre prise de paris (heures avant KO) — centrée sur H-24 = backtest bt_odds_h24
FOOT_SCAN_HEURES_MAX=30
FOOT_SCAN_HEURES_MIN=18

# Calibration P(couverture) AH (foot_calibration_ah.json via backtest --fit-calibration platt)
FOOT_CALIB_AH=true
# FOOT_CALIB_AH_FILE=foot_calibration_ah.json

# Preset P1 volume AH (parité backtest --p1-ah) — totaux inchangés
FOOT_P1_AH=true
FOOT_EV_MAX_AH=0.09
FOOT_EV_MIN_AH_TIER=true
FOOT_AH_MAX_LIGUE_SAISON=45

# Export CSV dashboard (PythonAnywhere)
# FOOT_HISTORIQUE_CSV=/home/chienblanc/data/historique_sniper.csv
# FOOT_CSV_LEGACY=/home/chienblanc/historique_sniper.csv
